# ═══════════════════════════════════════════════════════
# .env.example — AIRA Study Centre
# Required environment variables for production deployment
# ═══════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# Usage: node build.js reads .env and injects values into HTML/JS files.
# ═══════════════════════════════════════════════════════

# ── Module 1: Analytics ──
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
HOTJAR_SITE_ID=XXXXXXX

# ── Module 2: Google Sheets Webhook ──
SHEET_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ── Module 3: Security ──
RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY

# ── Module 4: Supabase ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_EDGE_FUNCTION_URL=https://YOUR_PROJECT.supabase.co/functions/v1/submit-lead

# ── General ──
ADMIN_EMAIL=admin@airastudycentre.com
PRODUCTION_DOMAIN=https://www.airastudycentre.com

# ── Module 4.5: Backup ──
GCS_BUCKET_NAME=aira-backups
